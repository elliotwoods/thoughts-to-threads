# =============================================================================
# Thoughts to Threads - environment variables
# Copy to .env.local for local dev, or set in the Vercel project settings.
# =============================================================================

# --- App ---------------------------------------------------------------------
# Public base URL of the deployment (no trailing slash). OPTIONAL: when unset,
# it is derived from the request host (and from VERCEL_URL on Vercel). Set it
# only to pin a canonical domain for links sent from background jobs / cron.
APP_BASE_URL=                 # https://your-app.example.com
# Random secret. Vercel Cron sends it as: Authorization: Bearer ${CRON_SECRET}
CRON_SECRET=
# Base64-encoded 32 random bytes for AES-256-GCM token encryption.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# --- Microsoft (Entra app registration, delegated) ---------------------------
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT=consumers           # "consumers" for personal-only, or "common"
# OPTIONAL override. Auto-derived from the request host as
# {origin}/api/auth/microsoft/callback. Set only to force a fixed URI.
MS_REDIRECT_URI=

# --- Threads (Meta app) ------------------------------------------------------
THREADS_APP_ID=
THREADS_APP_SECRET=
# OPTIONAL override. Auto-derived as {origin}/api/auth/threads/callback.
THREADS_REDIRECT_URI=

# --- Firebase Admin (service account) ----------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the literal \n escaping from the JSON key; it is unescaped at runtime.
FIREBASE_PRIVATE_KEY=

# --- Dashboard auth (Google OAuth) ------------------------------------------
# Create an OAuth 2.0 Client ID (type: Web) at console.cloud.google.com.
# Add {APP_BASE_URL}/api/auth/google/callback as an authorised redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated list of Google email addresses allowed to sign in.
ALLOWED_EMAILS=elliot@kimchiandchips.com

# --- Optional ----------------------------------------------------------------
# Where re-auth / failure alerts POST to (e.g. a Slack/Discord webhook).
NOTIFY_WEBHOOK_URL=
